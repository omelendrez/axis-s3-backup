# Backend API
API_URL="http://127.0.0.1:3000/api/"

# Documents folder (source files location)
DOCUMENTS_FOLDER_URI="/path/to/axis-documents"

# Database backup folder (optional - for database SQL backups)
# Files should be named like: YYYY-MM-DD.database_name.sql.gz
DATABASE_BACKUP_FOLDER_URI="/home/admin/public_html/software-suites.com/backup/admin_axis"

# AWS S3 Configuration
AWS_S3_BUCKET_NAME="axis-documents-bucket"
AWS_S3_BUCKET_REGION="us-east-1"
AWS_S3_BUCKET_ACCESS_KEY="your-access-key"
AWS_S3_BUCKET_SECRET_ACCESS_KEY="your-secret-key"

# Backup Configuration
BATCH_SIZE=20
BACKUP_FREQUENCY=3600000
